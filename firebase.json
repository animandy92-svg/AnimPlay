{
  "hosting": {
    "public": "client/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "destination": "https://animplay-k69u.onrender.com/api/$1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
