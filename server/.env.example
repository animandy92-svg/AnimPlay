# Environment variables for the AnimPlay server
# Copy this file to .env and fill in your values. NEVER commit .env.

# MongoDB connection string (Atlas or local). Example:
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/animplay_db?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/animplay_db

# Secret used to sign JWT auth tokens
JWT_SECRET=change-me-to-a-long-random-string

# Port the server listens on
PORT=3001
